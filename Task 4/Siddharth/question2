#include <stdio.h>
#include <stdlib.h>
#include <stdbool.h>
#include <string.h>


bool isMatchingPair(char open, char close) {
    if (open == '(' && close == ')') 
        return true;
    if (open == '{' && close == '}') 
        return true;
    if (open == '[' && close == ']') 
        return true;
    
    return false;
}

bool isBalanced(char *brac) {
    int n = strlen(brac); 
    
    char* stack = (char*)malloc(n *sizeof(char));
    int top = -1;

    for (int i = 0; i < n; i++) {
       
        if (brac[i] == '(' || brac[i] == '{' || brac[i] == '[') {
            stack[++top] = brac[i];
        } 
        
        else if (brac[i] == ')' || brac[i] == '}' || brac[i] == ']') {
            
            if (top == -1 || !isMatchingPair(stack[top--], brac[i])) {
                free(stack);
                return false;
            }
        }
    }

    
    bool result = (top == -1);
    free(stack);
    return result; 
    
}



int main() {
    char brac[] = "{[())}";

    if (isBalanced(brac))

        printf("It is Balanced \n");
    else
        printf("It is not balanced \n");

    return 0;
} //return  0;
