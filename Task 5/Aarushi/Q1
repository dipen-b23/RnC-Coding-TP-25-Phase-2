# Detect a loop 
class Node :
    def __init__(self,data):
        self.data = data
        self.next = None
class Linked_List:
    def __init__(self):
        self.head = None
    def append(self,data):
        new_Node = Node(data)
        if not self.head:
            self.head = new_Node
            return 
        temp = self.head
        while temp.next:
            temp= temp.next
        temp.next = new_Node
    def DetectLoop(self):
        temp1 = self.head
        temp2 = self.head
        while temp2 and temp2.next :
            if temp2 == temp2:
                return True
            temp1=temp1.next
            temp2=temp2.next.next
        return False
