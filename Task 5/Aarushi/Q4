class Node:
    def __init__(self,data):
        self.data = data
        self.right = None
        self.left = None
def Preorder(root,res):
    if root is None:
        return 
    res.append(root.data)
    Preorder(root.left,res)
    Preorder(root.right,res)
    return res

root = Node(2)
root.left = Node(1)
root.right = Node(3)
root.right.left = Node(0)
root.right.right = Node(1)

res = []
print(Preorder(root,res))
