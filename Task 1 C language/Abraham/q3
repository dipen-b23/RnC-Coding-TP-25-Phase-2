#include<stdio.h>
int main() {
    int i,j,k, n, sum;
    printf("Enter the number of elements: ");
    scanf("%d", &n);
    int a[n];
    
    printf("Enter the elements: ");
    for(i = 0; i<n; i++) {
        scanf("%d", &a[i]);
    }
    
    printf("Enter the desired number: ");
    scanf("%d", &sum);
    
    for( i =0; i<n-2; i++) {
        for(j =i+1; j<n-1; j++) {
            for(k =j+1; k<n;k++){
                if(a[i]+a[j]+a[k]==sum){
                    printf("Triplets with sum 9: (%d, %d, %d)\n ", a[i],a[j], a[k]);
                }
            }
        }
    }
}
