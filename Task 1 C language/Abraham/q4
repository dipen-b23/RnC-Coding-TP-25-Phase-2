#include <stdio.h>

int main(){
    int n1, n2, i, j;
    
    printf("Enter size of first array: ");
    scanf("%d", &n1);
    int a[n1];

    printf("Enter elements of first array: ");
    for (i = 0; i < n1; i++)
        scanf("%d", &a[i]);

    printf("Enter size of second array: ");
    scanf("%d", &n2);
    int b[n2];

    printf("Enter elements of second array: ");
    for (i = 0; i < n2; i++)
        scanf("%d", &b[i]);

    int result[n1 + n2];
    int resSize = 0;

    for (i = 0; i < n1; i++) {
        result[resSize++] = a[i];
    }

    for (i = 0; i < n2; i++) {
        int found = 0;
        for (j = 0; j < resSize; j++) {
            if (b[i] == result[j]) {
                found = 1;
                break;
            }
        }
        if (!found) {
            result[resSize++] = b[i];
        }
    }

    printf("\nUnion: ");
    for (i = 0; i < resSize; i++)
        printf("%d ", result[i]);

    printf("\nIntersection: ");
    for (i = 0; i < n1; i++) {
        for (j = 0; j < n2; j++) {
            if (a[i] == b[j]) {
                printf("%d ", a[i]);
                break;
            }
        }
    }

    return 0;
}
